generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id
  email     String     @unique
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  cartItems CartItem[]
  purchases Purchase[]
}

model Product {
  id          String     @id @default(uuid())
  title       String
  description String
  price       Int
  imageUrl    String?
  notionLink  String
  createdAt   DateTime   @default(now())
  cartItems   CartItem[]
  purchases   Purchase[]
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Purchase {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

enum Role {
  USER
  ADMIN
}
